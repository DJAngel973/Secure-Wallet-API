# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill it with real values

# DATABASE - PostgreSQL
POSTGRES_DB=wlet_pos
POSTGRES_USER=wlet_pos
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# PGADMIN - Web Administration
PGADMIN_DEFAULT_EMAIL=admin@wllet.local
PGADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD_HERE

# APPLICATION - Spring Boot
SPRING_PROFILES_ACTIVE=dev

# JWT Configuration
# Build with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64
JWT_EXPIRATION=86400000

# Server
SERVER_PORT=8080

# Volume (absolute path - adjust according to your system)
FILE_DATA_POSTGRES=/path/to/your/data/postgres_wallet